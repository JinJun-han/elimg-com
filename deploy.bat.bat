@echo off
REM ============================================================
REM  elimg.com 원클릭 배포 스크립트
REM  글로컬브릿지 · 한화오션 한국어교육
REM ============================================================
REM  사용법: 이 파일(배포.bat)을 더블클릭하면 자동으로
REM  1) 변경사항을 git에 추가
REM  2) 커밋 (메시지 자동 생성)
REM  3) GitHub로 푸시
REM  4) Cloudflare Pages 자동 배포 (1~2분 후 elimg.com 반영)
REM ============================================================

chcp 65001 > nul
cd /d "C:\Users\kodhj\elimg-com"

echo.
echo =====================================================
echo   elimg.com 배포를 시작합니다...
echo =====================================================
echo.

echo [1/4] 변경 파일 확인 중...
git status --short
echo.

echo [2/4] 변경 사항을 추가합니다...
git add -A
echo.

echo [3/4] 커밋 메시지를 입력하세요 (엔터만 누르면 자동 생성):
set /p MSG=메시지:
if "%MSG%"=="" set MSG=업데이트 %date% %time%

git commit -m "%MSG%"
echo.

echo [4/4] GitHub로 푸시 중...
git push
echo.

if %errorlevel% equ 0 (
    echo =====================================================
    echo   배포 성공! 1~2분 후 https://elimg.com 에 반영됩니다
    echo =====================================================
) else (
    echo =====================================================
    echo   푸시 실패 - 위 오류 메시지를 확인해 주세요
    echo =====================================================
)

echo.
pause
